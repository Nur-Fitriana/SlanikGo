generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Fasilitas {
  id          Int      @id @default(autoincrement())
  nama        String
  deskripsi   String
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tiket {
  id        Int      @id @default(autoincrement())
  hari      String   // weekday / weekend
  harga     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Info {
  id          Int      @id @default(autoincrement())
  jamBuka     String
  jamTutup    String
  alamat      String
  maps        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Galeri {
  id          Int      @id @default(autoincrement())
  urlGambar   String
  caption     String?
  createdAt   DateTime @default(now())
}